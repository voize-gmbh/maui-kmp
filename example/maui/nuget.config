<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      Local feed: output directory of `dotnet pack` on the binding project.
      The `just pack` recipe (or `./gradlew :composeApp:packIosBinding`) writes the .nupkg here.
      Mirrors the voize-sdk production setup where the feed is added via `dotnet nuget add source`.
    -->
    <add key="local" value="binding/bin/Release" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
