<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>MauiKmpExample.iOS</PackageId>
    <Version>0.1.0</Version>
    <TargetFramework>net10.0-ios</TargetFramework>
    <SupportedOSPlatformVersion>15.0</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>true</ImplicitUsings>
    <IsBindingProject>true</IsBindingProject>
    <NoWarn>NETSDK1202</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- C# interface definitions generated by the maui-kmp KSP processor. -->
    <ObjcBindingApiDefinition Include="generated/ApiDefinitions.cs" />
  </ItemGroup>

  <ItemGroup>
    <!--
      The Kotlin/Native framework, built by the example KMP project and copied here by the
      `copyXCFrameworkToBinding` Gradle task. Its baseName is "shared", so its ObjC class prefix
      is "Shared", matching the generated bindings above.
    -->
    <NativeReference Include="shared.xcframework">
      <Kind>Framework</Kind>
      <SmartLink>True</SmartLink>
    </NativeReference>
  </ItemGroup>
</Project>
